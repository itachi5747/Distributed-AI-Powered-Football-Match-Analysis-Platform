POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=footballiq
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/footballiq
DATABASE_URL_SYNC=postgresql://postgres:changeme@db:5432/footballiq

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QUEUE_INFERENCE=footballiq.inference
QUEUE_STATS=footballiq.stats
QUEUE_REPORTS=footballiq.reports
QUEUE_HIGHLIGHTS=footballiq.highlights

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_VIDEOS=footballiq-videos
MINIO_BUCKET_REPORTS=footballiq-reports
MINIO_BUCKET_FRAMES=footballiq-frames
MINIO_SECURE=false

JWT_ALGORITHM=HS256
JWT_SECRET_KEY=super-secret-change-in-production-must-be-32-chars-min
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

OPENAI_API_KEY=sk-...

MODEL_DIR=/models
DETECTION_MODEL=yolov8x.pt
CUDA_VISIBLE_DEVICES=0
FRAME_SKIP=1
DETECTION_CONFIDENCE=0.45
POSSESSION_THRESHOLD_M=2.0
SPRINT_THRESHOLD_KMH=25.0
